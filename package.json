{
  "name": "rubiks-cube-solver",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A full-stack TypeScript Rubik's Cube solver with image recognition, manual entry, a layer-by-layer solver, and step-by-step visual playback.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "heic2any": "^0.0.4",
    "onnxruntime-web": "^1.20.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^24.1.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vite-plugin-static-copy": "^3.1.4",
    "vitest": "^2.0.5"
  }
}
